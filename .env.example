# ==============================
# URLs BASE DO PROJETO
# ==============================

# URL da API do backend (Express/Node)
# Em desenvolvimento normalmente: http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# URL base completa da API (usado por alguns hooks como alias de NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Prefixo base das rotas públicas da API
NEXT_PUBLIC_API_BASE=/api

# URL do site frontend (Next.js)
# Em desenvolvimento: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL pública do app (usada em links absolutos)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ==============================
# AUTENTICAÇÃO / SEGURANÇA
# ==============================

# ==============================
# INTEGRAÇÕES (MAPA, PAGAMENTO, ETC)
# ==============================

# Mercado Pago (chave pública usada no frontend)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=trocar_por_sua_public_key

# Google Maps (se estiver usando no frontend)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=trocar_por_sua_api_key

# API de previsão do tempo (se estiver usando)
NEXT_PUBLIC_WEATHER_API_KEY=trocar_por_sua_api_key


# ==============================
# OUTROS
# ==============================

# Ambiente atual (apenas informativo, se você quiser usar)
NEXT_PUBLIC_APP_ENV=development
