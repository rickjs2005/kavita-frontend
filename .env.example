# ==============================
# URLs BASE DO PROJETO
# ==============================

# URL da API do backend (Express/Node)
# Em desenvolvimento normalmente: http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# URL base completa da API (usado por alguns hooks como alias de NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Prefixo base das rotas públicas da API
NEXT_PUBLIC_API_BASE=/api

# URL do site frontend (Next.js)
# Em desenvolvimento: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL pública do app (usada em links absolutos)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ==============================
# AUTENTICAÇÃO / SEGURANÇA
# ==============================

# ==============================
# INTEGRAÇÕES (MAPA, PAGAMENTO, ETC)
# ==============================

# Mercado Pago (chave pública usada no frontend)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=trocar_por_sua_public_key

# Google Maps (se estiver usando no frontend)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=trocar_por_sua_api_key

# API de previsão do tempo (se estiver usando)
NEXT_PUBLIC_WEATHER_API_KEY=trocar_por_sua_api_key


# ==============================
# OUTROS
# ==============================

# Ambiente atual (apenas informativo, se você quiser usar)
NEXT_PUBLIC_APP_ENV=development

# Email do DPO exibido em /privacidade e nos fallbacks do painel.
NEXT_PUBLIC_PRIVACY_EMAIL=privacidade@kavita.com.br


# ==============================
# OBSERVABILIDADE — SENTRY
# ==============================
# Error tracking. A integração é opt-in: ausência de
# NEXT_PUBLIC_SENTRY_DSN deixa todos os configs como no-op (build
# normal, sem network calls). Em dev/local pode deixar vazio.
#
# Setup em produção:
#   1. Criar projeto em https://sentry.io (Next.js platform)
#   2. Setar NEXT_PUBLIC_SENTRY_DSN com o DSN gerado
#   3. (Opcional) Setar SENTRY_AUTH_TOKEN + SENTRY_ORG + SENTRY_PROJECT
#      no CI para upload de source maps — sem isso, stack traces ficam
#      ofuscadas em produção (mas Sentry funciona)
#
# Comportamento padrão:
#   - Envia 100% dos erros 5xx + uncaught exceptions
#   - 10% das transactions (tracing), ajustável via NEXT_PUBLIC_SENTRY_TRACES_RATE
#   - Replay e profiling DESLIGADOS (sem custo de bundle/CPU)
#   - sendDefaultPii: false (LGPD)
#   - Scrubbing de CPF, email, telefone em strings livres
#   - Headers cookie/authorization/x-csrf-token nunca enviados
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_RATE=0.1
# NEXT_PUBLIC_SENTRY_RELEASE=

# Apenas para CI/build de produção — upload de source maps:
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
